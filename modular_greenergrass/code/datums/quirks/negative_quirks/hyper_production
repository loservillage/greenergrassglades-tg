
#define CUMPLUS_MULT_TESTI 50
#define CUMPLUS_MULT_VAGI 200
#define CUMPLUS_MULT_BOOBI 10

/datum/quirk/hyperprodgenitals
	name = "Hyper productive genitals"
	desc = "Your genitals create an enourmous amount of fluid. All this matter has to come somewhere though, try not to starve to death."
	value = -2
	gain_text = span_purple("Your lewd bits feel very hot, and you can hear them audiably churn quite loud as they kick into high production.")
	lose_text = span_purple("Your lewd bits return to normalish heat and sound.")
	medical_record_text = "Patient exhibits drastic increase in fluid production."
	icon = FA_ICON_HEART_CIRCLE_PLUS
	erp_quirk = TRUE

// Note: Increasing size increases production rate
// Production scales based on size and mob arousal

// Increase fluids
/datum/quirk/hyperprodgenitals/add(client/client_source)
	// Define quirk mob
	var/mob/living/carbon/human/quirk_mob = quirk_holder

	// Define potential fluid producing organ
	// Check if it exists
	// Multiply maximum fluid

	// Testicles
	var/obj/item/organ/genital/testicles/mob_testi = quirk_mob.get_organ_slot(ORGAN_SLOT_TESTICLES)
	if(mob_testi)
		mob_testi.production_quirk_modifier += CUMPLUS_MULT_TESTI

	// Vagina
	var/obj/item/organ/genital/vagina/mob_vagi = quirk_mob.get_organ_slot(ORGAN_SLOT_VAGINA)
	if(mob_vagi)
		mob_vagi.production_quirk_modifier += CUMPLUS_MULT_VAGI

	// Breasts
	var/obj/item/organ/genital/testicles/mob_boobi = quirk_mob.get_organ_slot(ORGAN_SLOT_BREASTS)
	if(mob_boobi)
		mob_boobi.production_quirk_modifier += CUMPLUS_MULT_BOOBI

// Reduce fluids
/datum/quirk/hyperprodgenitals/remove()
	// Define quirk mob
	var/mob/living/carbon/human/quirk_mob = quirk_holder

	// Identical to above but divides

	// Testicles
	var/obj/item/organ/genital/testicles/mob_testi = quirk_mob.get_organ_slot(ORGAN_SLOT_TESTICLES)
	if(mob_testi)
		mob_testi.production_quirk_modifier -= CUMPLUS_MULT_TESTI

	// Vagina
	var/obj/item/organ/genital/vagina/mob_vagi = quirk_mob.get_organ_slot(ORGAN_SLOT_VAGINA)
	if(mob_vagi)
		mob_vagi.production_quirk_modifier -= CUMPLUS_MULT_VAGI

	// Breasts
	var/obj/item/organ/genital/testicles/mob_boobi = quirk_mob.get_organ_slot(ORGAN_SLOT_BREASTS)
	if(mob_boobi)
		mob_boobi.production_quirk_modifier -= CUMPLUS_MULT_BOOBI

#undef CUMPLUS_MULT_GLOBAL
#undef CUMPLUS_MULT_TESTI
#undef CUMPLUS_MULT_VAGI
#undef CUMPLUS_MULT_BOOBI
